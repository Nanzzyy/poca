# Database
DATABASE_URL=postgresql+asyncpg://tourism:tourism@localhost:5433/tourism
DATABASE_URL_SYNC=postgresql://tourism:tourism@localhost:5433/tourism

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# AI Provider (LiteLLM)
AI_PROVIDER=gemini
AI_MODEL=gemini/gemini-2.0-flash
AI_API_KEY=

# App
APP_NAME=Poca - AI Tourism Companion
DEBUG=true
API_PREFIX=/api/v1
CORS_ORIGINS=*
